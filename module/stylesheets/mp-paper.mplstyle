# Font settings
font.size         : 12
font.family       : sans-serif
font.sans-serif   : Helvetica, TeX Gyre Heros

# Axes label size (separate from general font.size)
axes.labelsize    : 12
axes.labelpad     : 6      # space between label and tick labels

# Axes spines
axes.spines.right : False
axes.spines.top   : False
axes.linewidth    : 1

# Figure resolution
figure.figsize    : 3, 3
figure.dpi        : 200     # on-screen
savefig.dpi       : 900     # file exports

figure.autolayout     : True

# save format
savefig.format        : pdf     # or svg for vector; png for raster
savefig.bbox          : tight   # never clip labels on export
savefig.transparent   : True
pdf.fonttype	      : 42	# embeds fonts as TrueType, making text editable
svg.fonttype : none
ps.fonttype	      : 42

# Line settings
lines.linewidth   : 1

# Legend
legend.frameon    : False

# Marker styling
lines.markeredgecolor : black
lines.markerfacecolor : auto

# Tick lengths
xtick.major.size  : 4
ytick.major.size  : 4
xtick.major.width : 0.8
ytick.major.width : 0.8
xtick.direction       : out
ytick.direction       : out
